# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  AutoHelper — Environment Variables                                         ║
# ║  Copy this file to .env and fill in the actual values.                      ║
# ║  NEVER commit .env to version control!                                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=autohelper
POSTGRES_USER=autohelper
POSTGRES_PASSWORD=change_me_strong_password

# ─── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password
STORAGE_BUCKET_NAME=autohelper

# ─── ASP.NET Core / Backend ───────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# Must be at least 32 characters long for HS256 JWT signing
JWT_SECRET=change_me_use_at_least_32_characters_long_secret_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# Public vars are embedded at build time — rebuild the image after changing them
NEXT_PUBLIC_API_URL=http://localhost:8080
