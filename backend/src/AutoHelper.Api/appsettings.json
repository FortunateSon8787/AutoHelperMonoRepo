{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId,-14} {SourceContext}{NewLine}         {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/autohelper-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] [{EnvironmentName}] {CorrelationId,-14} {SourceContext}{NewLine}         {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "Http": {
      "Enabled": true,
      "LogRequestHeaders": true,
      "IgnorePaths": ["health"]
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=autohelper;Username=autohelper;Password=autohelper_local_password"
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "ValidAudiences": [ "autohelper-api" ],
        "ValidIssuers": [ "autohelper-api" ]
      }
    }
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION_USE_USER_SECRETS",
    "Issuer": "autohelper-api",
    "Audience": "autohelper-api",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Storage": {
    "Provider": "MinIO",
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "autohelper",
    "CloudflareAccountId": "",
    "PublicBaseUrl": ""
  },
  "Stripe": {
    "SecretKey": "CHANGE_ME",
    "WebhookSecret": "CHANGE_ME"
  },
  "OpenAI": {
    "ApiKey": "CHANGE_ME",
    "Model": "gpt-4o"
  },
  "Database": {
    "AutoMigrateOnStartup": true
  },
