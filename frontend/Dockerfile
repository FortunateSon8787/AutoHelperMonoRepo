# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  AutoHelper Frontend — Multi-stage Dockerfile                               ║
# ║  Stage 1 (deps)    : install production dependencies                        ║
# ║  Stage 2 (builder) : full install + next build (standalone output)          ║
# ║  Stage 3 (runner)  : minimal Node runtime, non-root user                    ║
# ║                                                                              ║
# ║  Requires next.config.ts → output: "standalone"                             ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Stage 1: Install production deps (cached separately) ──────────────────────
FROM node:22-alpine AS deps
WORKDIR /app

# Install libc compatibility layer needed by some native packages
RUN apk add --no-cache libc6-compat

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# ── Stage 2: Build ────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app

RUN apk add --no-cache libc6-compat

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

# NEXT_PUBLIC_* variables are embedded into the JS bundle at build time.
# Pass them via --build-arg in docker compose / CI.
ARG NEXT_PUBLIC_API_URL=http://localhost:8080
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

ARG NEXT_PUBLIC_GOOGLE_MAPS_KEY
ENV NEXT_PUBLIC_GOOGLE_MAPS_KEY=$NEXT_PUBLIC_GOOGLE_MAPS_KEY

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

# ── Stage 3: Production runner ────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Install curl for health-check probe
RUN apk add --no-cache curl

# Create non-root user
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# Copy public assets
COPY --from=builder /app/public ./public

# Copy standalone server and static assets with correct ownership
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static     ./.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# next start in standalone mode — server.js is generated by Next.js
CMD ["node", "server.js"]
